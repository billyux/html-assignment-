<!DOCTYPE html>
<head>
<title>모의투자</title>
    <style>
        body { font-family: 'Pretendard', sans-serif; background: #f0f2f5; padding: 20px; }
        .dashboard { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 20px; max-width: 1000px; margin: 0 auto; }
        .card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { text-align: right; padding: 12px 8px; border-bottom: 1px solid #eee; }
        .plus { color: #e74c3c; font-weight: bold; }
        .minus { color: #3498db; font-weight: bold; }
        input { padding: 10px; border: 1px solid #ddd; border-radius: 6px; width: 60%; }
        button { padding: 10px 20px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; }
        #stockPreview { margin-top: 20px; padding: 15px; background: #f8f9fa; border-radius: 8px; display: none; }
    </style>
</head>
<body>

<div class="dashboard">
    <div class="card">
        <h2>예수금: <span id="myBalance">0</span> USD</h2>
        <table>
            <thead><tr><th>종목</th><th>수량</th><th>수익률</th></tr></thead>
            <tbody id="portfolioTable"></tbody>
        </table>
    </div>

    <div class="card">
        <h2>주식 주문</h2>
        <input type="text" id="symbolInput" placeholder="종목코드 (예: TSLA)">
        <button id="searchBtn">조회</button>

        <div id="stockPreview">
            <h3 id="targetName">---</h3>
            <div id="targetPrice" style="font-size: 1.5rem;">$0.00</div>
            <input type="number" id="orderAmount" value="1" min="1">
            <button id="buyBtn">매수</button>
            <button id="sellBtn">매도</button>
        </div>
    </div>
</div>

<script>
    const API_KEY = 'd80jnapr01qt5k5v7ns0d80jnapr01qt5k5v7nsg';
    let userData = JSON.parse(localStorage.getItem('stockGameV2')) || { balance: 10000, portfolio: {} };
    let currentStock = { symbol: '', price: 0 };

    function updateUI() {
        document.getElementById('myBalance').innerText = userData.balance.toLocaleString(undefined, {minimumFractionDigits: 2});
        const tableBody = document.getElementById('portfolioTable');
        tableBody.innerHTML = '';
        for (const symbol in userData.portfolio) {
            const stock = userData.portfolio[symbol];
            if (stock.qty <= 0) continue;
            const profitRate = ((currentStock.symbol === symbol ? currentStock.price : stock.avg) - stock.avg) / stock.avg * 100;
            tableBody.innerHTML += `<tr><td>${symbol}</td><td>${stock.qty}</td>
                <td class="${profitRate >= 0 ? 'plus' : 'minus'}">${profitRate.toFixed(2)}%</td></tr>`;
        }
        localStorage.setItem('stockGameV2', JSON.stringify(userData));
    }

    async function searchStock() {
        const symbol = document.getElementById('symbolInput').value.toUpperCase();
        const res = await fetch(`https://finnhub.io/api/v1/quote?symbol=${symbol}&token=${API_KEY}`);
        const data = await res.json();
        if (data.c === 0) return alert("종목 오류");
        currentStock = { symbol: symbol, price: data.c };
        document.getElementById('stockPreview').style.display = 'block';
        document.getElementById('targetName').innerText = symbol;
        document.getElementById('targetPrice').innerText = `$${data.c.toFixed(2)}`;
        updateUI();
    }

    function executeTrade(type) {
        const qty = parseInt(document.getElementById('orderAmount').value);
        const totalValue = currentStock.price * qty;
        const symbol = currentStock.symbol;
        if (type === 'BUY') {
            if (userData.balance < totalValue) return alert("잔액 부족");
            userData.balance -= totalValue;
            const s = userData.portfolio[symbol] || { qty: 0, avg: 0 };
            s.avg = ((s.qty * s.avg) + totalValue) / (s.qty + qty);
            s.qty += qty;
            userData.portfolio[symbol] = s;
        } else {
            const s = userData.portfolio[symbol];
            if (!s || s.qty < qty) return alert("수량 부족");
            userData.balance += totalValue;
            s.qty -= qty;
        }
        updateUI();
    }

    
    document.getElementById('searchBtn').onclick = searchStock;
    document.getElementById('buyBtn').onclick = function() { executeTrade('BUY'); };
    document.getElementById('sellBtn').onclick = function() { executeTrade('SELL'); };

    updateUI();
</script>
</body>
</html>
